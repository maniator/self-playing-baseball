{
  "name": "blipit-legends",
  "version": "1.0.1",
  "author": "Naftali Lubin <naftalilubin@gmail.com>",
  "license": "GPL-3.0-only",
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dev:deploy": "vite build && vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"e2e/**/*.ts\" \"playwright.config.ts\" \"**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"e2e/**/*.ts\" \"playwright.config.ts\" \"**/*.md\"",
    "lint": "eslint src e2e playwright.config.ts",
    "lint:fix": "eslint src e2e playwright.config.ts --fix",
    "prepare": "husky",
    "test": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "yarn build && playwright test",
    "test:e2e:build": "yarn build",
    "test:e2e:server": "npx vite preview --port 5173",
    "test:e2e:run": "playwright test",
    "test:e2e:run:shard1": "playwright test --project=determinism --project=desktop --project=pixel-7 --project=pixel-5 --shard=1/3",
    "test:e2e:run:shard2": "playwright test --project=determinism --project=desktop --project=pixel-7 --project=pixel-5 --shard=2/3",
    "test:e2e:run:shard3": "playwright test --project=determinism --project=desktop --project=pixel-7 --project=pixel-5 --shard=3/3",
    "test:e2e:run:shard4": "playwright test --project=tablet --project=iphone-15-pro-max --project=iphone-15 --shard=1/3",
    "test:e2e:run:shard5": "playwright test --project=tablet --project=iphone-15-pro-max --project=iphone-15 --shard=2/3",
    "test:e2e:run:shard6": "playwright test --project=tablet --project=iphone-15-pro-max --project=iphone-15 --shard=3/3",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "node scripts/ensure-docker-snapshot-update.cjs && playwright test --update-snapshots",
    "typecheck": "tsc --noEmit",
    "typecheck:e2e": "tsc --noEmit -p e2e/tsconfig.json"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@vercel/analytics": "^2.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "react-router": "^7.6.0",
    "rxdb": "17.0.0-beta.7",
    "rxjs": "^7.8.2",
    "styled-components": "^6.3.10",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-prettier": "^5",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-simple-import-sort": "^12",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16",
    "husky": "^9.1.7",
    "jsdom": "26.0.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "3.2.4",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0"
  },
  "lint-staged": {
    "*.md": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run --reporter=verbose"
    ],
    "playwright.config.ts": [
      "prettier --write"
    ]
  },
  "browserslist": "> 0.5%, last 2 versions, not dead"
}
